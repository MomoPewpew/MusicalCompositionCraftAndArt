{
  "name": "musical-composition-viewer",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node scripts/ensure-dev.mjs && node scripts/prepare-assets.mjs && next dev -H 0.0.0.0 -p 3001",
    "humanize-midi": "python3 ../scripts/humanize_midi_assets.py",
